{
  "name": "ai-pr-generator",
  "version": "0.1.0",
  "private": true,
  "description": "Production-style scaffold for AI-assisted commit, PR, review, and code explanation generation.",
  "workspaces": ["client"],
  "scripts": {
    "dev:client": "npm --workspace client run dev",
